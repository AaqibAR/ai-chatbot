import { useEffect, useState } from "react"

function KnowledgeBase() {
  const [faqs, setFaqs] = useState([])
  const [newQ, setNewQ] = useState("")
  const [newA, setNewA] = useState("")
  const [adding, setAdding] = useState(false)

  const fetchFaqs = () => {
    fetch("http://localhost:8000/faqs")
      .then(r => r.json())
      .then(setFaqs)
      .catch(console.error)
  }

  useEffect(() => { fetchFaqs() }, [])

  const handleAdd = async () => {
    if (!newQ.trim() || !newA.trim()) return alert("Please fill both fields!")
    setAdding(true)
    try {
      await fetch("http://localhost:8000/learn", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ id: null, question: newQ, answer: newA })
      })
      setNewQ("")
      setNewA("")
      fetchFaqs()
    } catch (e) {
      alert("Failed to add FAQ.")
    } finally {
      setAdding(false)
    }
  }

  return (
    <div>
      <div className="add-faq-card">
        <h3 className="section-title">Add new knowledge</h3>
        <input
          className="train-input"
          placeholder="Question — e.g. Do you offer airport pickup?"
          value={newQ}
          onChange={e => setNewQ(e.target.value)}
        />
        <textarea
          className="train-input"
          placeholder="Answer — e.g. Yes! Airport pickup is available for LKR 2,500."
          value={newA}
          onChange={e => setNewA(e.target.value)}
          rows={3}
        />
        <button className="train-btn" onClick={handleAdd} disabled={adding}>
          {adding ? "Adding..." : "Add to Knowledge Base"}
        </button>
      </div>

      <h3 className="section-title" style={{ marginTop: "24px" }}>
        Current knowledge base ({faqs.length} entries)
      </h3>
      <div className="faq-list">
        {faqs.map(f => (
          <div key={f.id} className="faq-card">
            <p className="faq-q">Q: {f.question}</p>
            <p className="faq-a">A: {f.answer}</p>
          </div>
        ))}
      </div>
    </div>
  )
}

export default KnowledgeBase